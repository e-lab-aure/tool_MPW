# Master Pod Warden - Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs

# Chemin de la socket Podman sur l'hote (rootless)
# Pour trouver le bon chemin : echo $XDG_RUNTIME_DIR/podman/podman.sock
# Exemple typique pour UID 1000 : /run/user/1000/podman/podman.sock
PODMAN_SOCKET_PATH_HOST=/run/user/1000/podman/podman.sock
