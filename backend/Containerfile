# --- Master Pod Warden - Backend ---
# Image Python slim pour reduire la surface d'attaque.
# Note securite : en mode rootless Podman, root dans le conteneur est mappe
# sur l'uid de l'utilisateur hote (non-root). L'isolation est garantie par
# le user namespace - il n'y a pas de privilege root reel sur l'hote.
FROM docker.io/library/python:3.12-slim

# Cree le repertoire de logs
RUN mkdir -p /var/log/mpw

WORKDIR /app

# Installe les dependances avant de copier le code (optimise le cache des layers)
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# Copie le code source
COPY app/ ./app/

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--no-access-log"]
